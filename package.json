    "react-dom": "19.1.0",
    "viem": "2.33.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "9.33.0",
    "@types/node": "24.2.1",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "eslint": "9.33.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.4",
    "globals": "16.3.0",
    "npm-package-json-lint": "10.4.0",
    "prettier": "3.6.2",
    "tsx": "4.20.3",
    "typescript": "5.9.2",
